# Copy to .env and fill in values. Never commit .env

# Optional: default account for gog (email/calendar integration)
# GOG_ACCOUNT=

# Optional: Telegram alerts (if you implement alerts via OpenClaw message tool,
# you won't need this; keep secrets out of code and out of git.)
# TELEGRAM_CHAT_ID=

# IBKR (not usually secret, but configurable)
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=7
IBKR_ACCOUNT=

# Bot runtime
BOT_PAPER_ONLY=true
